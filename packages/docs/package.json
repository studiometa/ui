{
  "name": "@studiometa/ui-docs",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently 'npm run dev:playground' 'npm run dev:vitepress' --names 'play,docs'",
    "dev:playground": "npm run watch --workspace=@studiometa/ui-playground",
    "dev:vitepress": "vitepress dev .",
    "prebuild": "npm run build --workspace=@studiometa/ui-playground",
    "build": "vitepress build .",
    "postbuild": "ln -sf ../../../api/public .vitepress/dist/api"
  },
  "dependencies": {
    "@studiometa/js-toolkit": "3.4.3"
  },
  "devDependencies": {
    "@iconify-json/octicon": "1.2.17",
    "@shikijs/vitepress-twoslash": "3.15.0",
    "@studiometa/playground-preview": "0.3.4",
    "@studiometa/tailwind-config": "2.1.0",
    "autoprefixer": "10.4.21",
    "concurrently": "9.2.1",
    "tailwindcss": "3.4.18",
    "unplugin-icons": "22.5.0",
    "unplugin-vue-components": "30.0.0",
    "vitepress": "2.0.0-alpha.12",
    "vitepress-plugin-llms": "1.9.1"
  }
}
