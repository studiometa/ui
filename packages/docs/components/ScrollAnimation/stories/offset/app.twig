<div class="flex items-center justify-center w-full h-screen">
  Scroll down ↓
</div>

{# Default offset: "start end / end start" #}
{# Animation starts when top of element reaches bottom of viewport #}
{# Animation ends when bottom of element reaches top of viewport #}
<div data-component="ScrollAnimationTimeline"
  data-option-debug
  class="h-[300vh]">
  <div class="sticky top-0 flex items-center justify-center w-full h-screen">
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1 }|json_encode }}"
        class="w-48 h-48 rounded-2xl bg-blue-500"></div>
      <p class="mt-4 text-sm text-gray-600">Default offset</p>
      <p class="mt-1 text-xs text-gray-400">"start end / end start"</p>
    </div>
  </div>
</div>

<div class="flex items-center justify-center w-full h-screen">
  Scroll down ↓
</div>

{# Center offset: "center center / center center" #}
{# Animation plays only when element center is at viewport center #}
<div data-component="ScrollAnimationTimeline"
  data-option-debug
  data-option-offset="start center / end center"
  class="h-[300vh]">
  <div class="sticky top-0 flex items-center justify-center w-full h-screen">
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1 }|json_encode }}"
        class="w-48 h-48 rounded-2xl bg-green-500"></div>
      <p class="mt-4 text-sm text-gray-600">Centered offset</p>
      <p class="mt-1 text-xs text-gray-400">"start center / end center"</p>
    </div>
  </div>
</div>

<div class="flex items-center justify-center w-full h-screen">
  Scroll down ↓
</div>

{# Top section offset: "start start / end start" #}
{# Animation starts when top of element reaches top of viewport #}
{# Animation ends when bottom of element reaches top of viewport #}
<div data-component="ScrollAnimationTimeline"
  data-option-debug
  data-option-offset="start start / end start"
  class="h-[300vh]">
  <div class="sticky top-0 flex items-center justify-center w-full h-screen">
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1 }|json_encode }}"
        class="w-48 h-48 rounded-2xl bg-red-500"></div>
      <p class="mt-4 text-sm text-gray-600">Top section offset</p>
      <p class="mt-1 text-xs text-gray-400">"start start / end start"</p>
    </div>
  </div>
</div>

<div class="flex items-center justify-center w-full h-screen">
  Scroll up ↑
</div>
