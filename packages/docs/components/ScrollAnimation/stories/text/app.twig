<style>
  .text-9xl { font-size: 18rem; }
</style>

<div class="flex items-center justify-center w-full h-screen">
  Scroll down ↓
</div>

<div data-component="ScrollAnimationTimeline"
  class="z-10 relative bg-gray-200"
  style="contain: content;">
  <div data-component="ScrollAnimationTarget"
    data-option-to="{{ { scale: 1.1 }|json_encode }}"
    class="flex items-center justify-around w-full max-w-xl h-screen mx-auto text-7xl m:text-9xl font-extrabold text-blue-800">
    <span data-component="ScrollAnimationTarget"
      data-option-to="{{ { x: -300, y: -100, rotate: -80, scale: 2 }|json_encode }}">
      <span class="block pointer-events-none">D</span>
    </span>
    <span data-component="ScrollAnimationTarget"
      data-option-to="{{ { x: -150, y: -50, rotate: -40, scale: 1.5 }|json_encode }}">
      <span class="block pointer-events-none">E</span>
    </span>
    <span data-component="ScrollAnimationTarget"
      data-option-to="{{ { x: 150, y: -50, rotate: 40, scale: 1.5 }|json_encode }}">
      <span class="block pointer-events-none">M</span>
    </span>
    <span data-component="ScrollAnimationTarget"
      data-option-to="{{ { x: 300, y: -100, rotate: 80, scale: 2 }|json_encode }}">
      <span class="block pointer-events-none">O</span>
    </span>
  </div>
</div>

<div class="flex items-center justify-center w-full h-screen">
  Scroll up ↑
</div>
