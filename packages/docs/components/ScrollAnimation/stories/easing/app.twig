<div class="flex items-center justify-center w-full h-screen">
  Scroll down ↓
</div>

<div data-component="ScrollAnimationTimeline" class="h-[300vh]">
  <div class="sticky top-0 flex gap-8 items-center justify-center w-full h-screen">
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0, rotate: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1, rotate: 360 }|json_encode }}"
        data-option-easing="[0, 0, 1, 1]"
        class="w-24 h-24 rounded-2xl bg-blue-500"></div>
      <p class="mt-4 text-sm text-gray-600">linear</p>
    </div>
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0, rotate: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1, rotate: 360 }|json_encode }}"
        data-option-easing="[0.25, 0.1, 0.25, 1]"
        class="w-24 h-24 rounded-2xl bg-green-500"></div>
      <p class="mt-4 text-sm text-gray-600">ease</p>
    </div>
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0, rotate: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1, rotate: 360 }|json_encode }}"
        data-option-easing="[0.42, 0, 1, 1]"
        class="w-24 h-24 rounded-2xl bg-red-500"></div>
      <p class="mt-4 text-sm text-gray-600">ease-in</p>
    </div>
    <div class="text-center">
      <div
        data-component="ScrollAnimationTarget"
        data-option-from="{{ { scale: 0, opacity: 0, rotate: 0 }|json_encode }}"
        data-option-to="{{ { scale: 1, opacity: 1, rotate: 360 }|json_encode }}"
        data-option-easing="[0, 0, 0.58, 1]"
        class="w-24 h-24 rounded-2xl bg-purple-500"></div>
      <p class="mt-4 text-sm text-gray-600">ease-out</p>
    </div>
  </div>
</div>

<div class="flex items-center justify-center w-full h-screen">
  Scroll up ↑
</div>
