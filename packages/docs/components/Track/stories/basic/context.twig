<section
  data-component="TrackContext"
  data-option-data='{"page_type": "product", "product_id": "SKU123", "product_name": "Example Product"}'>

  <div class="space-y-4">
    <p class="text-sm text-gray-600">
      All buttons inherit context data from the parent <code>TrackContext</code>.
    </p>

    <div class="flex gap-4">
      <button
        data-component="Track"
        data-track:click='{"action": "add_to_cart"}'
        class="px-4 py-2 bg-blue-400 text-white rounded hover:bg-blue-500">
        Add to Cart
      </button>

      <button
        data-component="Track"
        data-track:click='{"action": "add_to_wishlist"}'
        class="px-4 py-2 bg-green-400 text-white rounded hover:bg-green-500">
        Add to Wishlist
      </button>
    </div>

    <div>
      <p class="text-sm font-medium text-gray-700 mb-2">dataLayer:</p>
      <pre
        data-debug-datalayer
        class="p-3 bg-gray-100 rounded text-xs overflow-auto max-h-48 text-gray-800">[]</pre>
    </div>
  </div>
</section>
