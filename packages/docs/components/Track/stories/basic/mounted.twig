<!-- This element tracks data on page load -->
<div
  data-component="Track"
  data-track:mounted='{"event": "page_view", "page_type": "home", "user_logged_in": false}'
  hidden>
</div>

<p class="text-sm text-gray-600 mb-4">
  The <code>page_view</code> event was dispatched when this component mounted.
</p>

<div>
  <p class="text-sm font-medium text-gray-700 mb-2">dataLayer:</p>
  <pre
    data-debug-datalayer
    class="p-3 bg-gray-100 rounded text-xs overflow-auto max-h-48 text-gray-800">[]</pre>
</div>
