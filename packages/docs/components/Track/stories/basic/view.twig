<div class="space-y-4">
  <p class="text-sm text-gray-600">
    Scroll down to see the product cards. Each card tracks an impression when it becomes visible.
  </p>

  <div class="h-[200px] overflow-y-auto border rounded p-4 space-y-4">
    <div class="h-[150px]"></div>

    <div
      data-component="Track"
      data-on:view.once='{"event": "product_impression", "product_id": "SKU001", "product_name": "Product A"}'
      class="p-4 bg-blue-100 rounded">
      Product A - Impression tracked once when visible
    </div>

    <div
      data-component="Track"
      data-on:view.once='{"event": "product_impression", "product_id": "SKU002", "product_name": "Product B"}'
      class="p-4 bg-green-100 rounded">
      Product B - Impression tracked once when visible
    </div>

    <div
      data-component="Track"
      data-on:view.once='{"event": "product_impression", "product_id": "SKU003", "product_name": "Product C"}'
      class="p-4 bg-yellow-100 rounded">
      Product C - Impression tracked once when visible
    </div>

    <div class="h-[150px]"></div>
  </div>
</div>
