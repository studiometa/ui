<a
  href="#"
  data-component="Track"
  data-on:click.prevent='{"event": "link_click", "method": "left_click"}'
  data-on:mouseenter='{"event": "link_hover"}'
  class="inline-block px-4 py-2 bg-purple-500 text-white rounded">
  Hover and Click Me
</a>

<p class="mt-4 text-sm text-gray-600">
  This link tracks both hover (mouseenter) and click events.
</p>
