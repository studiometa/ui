<div class="space-y-4">
  <a
    href="#"
    data-component="Track"
    data-on:click.prevent='{"event": "link_click", "method": "left_click"}'
    data-on:mouseenter='{"event": "link_hover"}'
    class="inline-block px-4 py-2 bg-blue-400 text-white rounded hover:bg-blue-500">
    Hover and Click Me
  </a>

  <p class="text-sm text-gray-600">
    This link tracks both hover (<code>mouseenter</code>) and click events.
  </p>

  <div>
    <p class="text-sm font-medium text-gray-700 mb-2">dataLayer:</p>
    <pre
      data-debug-datalayer
      class="p-3 bg-gray-100 rounded text-xs overflow-auto max-h-48 text-gray-800">[]</pre>
  </div>
</div>
