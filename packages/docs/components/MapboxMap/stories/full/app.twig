<link rel="stylesheet" href="https://esm.sh/mapbox-gl@3.13.0/dist/mapbox-gl.css" />

<div data-component="MapboxMap"
  data-option-access-token="pk.eyJ1IjoiYWdlbmNlc3R1ZGlvbWV0YSIsImEiOiJjbTZxZXZidzYxaXR3MmtzaG5qNzc3NGxqIn0.c_YVpXQptiZtOgzj_5jvaw"
  data-option-zoom="12"
  data-option-center="[2.35, 48.86]"
  class="w-full max-w-4xl h-96 grid grid-cols-1 grid-rows-1">
  <div data-ref="container"></div>

  <!-- Navigation control -->
  <div hidden data-component="MapboxNavigationControl"
    data-option-position="top-right">
  </div>

  <!-- Geolocate control -->
  <div hidden data-component="MapboxGeolocateControl"
    data-option-track-user-location>
  </div>

  <!-- Marker with popup -->
  <div hidden data-component="MapboxMarker"
    data-option-lng-lat="[2.35, 48.86]">
    <div data-component="MapboxPopup">
      <h3>Paris</h3>
      <p>Capital of France</p>
    </div>
  </div>

  <!-- Standalone popup -->
  <div hidden data-component="MapboxPopup"
    data-option-lng-lat="[2.29, 48.86]">
    <p>Near the Eiffel Tower</p>
  </div>
</div>
