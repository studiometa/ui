{% set count = 12 %}
<div data-component="Frame" id="frame" data-option-log>
  <header class="flex gap-4 justify-between p-4">
    <h1 class="font-bold">My shop</h1>
    <div data-component="FrameLoader"
      data-option-enter-from="opacity-0 scale-0"
      data-option-enter-active="transition duration-500 ease-out-expo"
      data-option-leave-active="transition duration-500 ease-in-expo"
      data-option-leave-to="opacity-0 scale-0"
      class="flex items-center mr-auto opacity-0 scale-0">
      {{
        include(
          '@ui/Icon/Icon.twig',
          {
            name: 'svg-spinners:ring-resize',
            attr: {
              class: 'block h-[0.6lh] [&>svg]:w-full [&>svg]:h-full'
            }
          }
        )
      }}
    </div>
    {# The cart drawer is a Dialog; this Action button opens it. #}
    <button type="button"
      data-component="Action"
      data-on:click="Dialog(#cart)->target.open()"
      class="inline-flex gap-2 items-center border-b">
      <span data-component="FrameTarget" id="cart-summary">Cart: 0</span>
    </button>
  </header>

  {# Cart drawer — a right-anchored Dialog. The host carries NO display utility,
     so a closed drawer stays display:none instead of covering the page. #}
  <dialog id="cart"
    data-component="Action Dialog"
    data-on:cancel.prevent="Dialog.close()"
    data-on:click="event.target === $el && Dialog.close()"
    class="fixed inset-0 m-0 p-0 w-full h-full max-w-none max-h-none bg-transparent">
    {# Fading backdrop — a Transition child, dismisses on click. #}
    <div data-component="Action Transition"
      data-on:click="Dialog(#cart)->target.close()"
      data-option-enter-active="transition duration-300 ease-out"
      data-option-enter-from="opacity-0"
      data-option-leave-active="transition duration-200 ease-in"
      data-option-leave-to="opacity-0"
      data-option-leave-keep
      class="fixed inset-0 bg-white/20 opacity-0"></div>

    {# Right-anchored panel sliding in from the edge — a second Transition child. #}
    <div data-component="Transition"
      data-option-enter-active="transition duration-500 ease-out-expo"
      data-option-enter-from="translate-x-full"
      data-option-leave-active="transition duration-500 ease-in-expo"
      data-option-leave-to="translate-x-full"
      data-option-leave-keep
      class="absolute inset-y-0 right-0 w-screen max-w-sm p-8 bg-white border-l translate-x-full">
      <div class="flex justify-end pb-8">
        <button type="button"
          data-component="Action"
          data-on:click="Dialog(#cart)->target.close()"
          class="inline-flex gap-2 items-center border-b">
          Close
        </button>
      </div>
      <div data-component="FrameTarget"
        id="cart-content"
        data-option-enter-from="opacity-0"
        data-option-enter-active="transition ease-in-out"
        data-option-leave-active="transition ease-in-out"
        data-option-leave-to="opacity-0">
        <p class="opacity-50">Your cart is empty.</p>
      </div>
    </div>
  </dialog>
  <main class="grid xs:grid-cols-2 m:grid-cols-3 xl:grid-cols-4 gap-8 p-4">
    {% for article in 1..count %}
      {% set price = random(1, 4) ~ '00 €' %}
      <article class="relative grid gap-4">
        {{
          include(
            '@ui/Figure/Figure.twig',
            {
              src: 'https://picsum.photos/seed/KEY/300/200'|replace({
                KEY: loop.index + 10
              }),
              width: 300,
              height: 200,
              fit: 'cover',
              attr: {
                class: 'rounded overflow-hidden'
              }
            }
          )
        }}
        <div class="flex gap-4 justify-between items-baseline">
          <div>
            <a data-component="Action"
              data-on:click.prevent
              href="#"
              class="inline-block border-b after:absolute after:inset-0">
              Item #{{ loop.index }}
            </a>
            <br /> {{ price }}
          </div>
          <form data-component="FrameForm Action"
            action="/api/"
            method="POST"
            data-on:frame-content="Dialog(#cart)->target.open()"
            class="flex items-center gap-2">
            {%- set cart_content -%}
              <span data-component="FrameTarget" id="cart-summary">
                Cart: 1
              </span>
              <div data-component="FrameTarget"
                id="cart-content"
                data-option-enter-from="opacity-0"
                data-option-enter-active="transition ease-in-out"
                data-option-leave-active="transition ease-in-out"
                data-option-leave-to="opacity-0">
                <article class="flex justify-between gap-4">
                  <div>
                    <a data-component="Action" data-on:click.prevent href="#" class="inline-block border-b">
                      Item #{{ loop.index }}
                    </a>
                  </div>
                  <span class="ml-auto">{{ price }}</span>
                  <form data-component="FrameForm Action"
                    action="/api/"
                    method="POST"
                    class="flex items-center gap-2">
                    <input type="hidden" name="wait" value="1" />
                    <textarea class="hidden" readonly name="content">
                      <span data-component="FrameTarget" id="cart-summary">
                        Cart: 0
                      </span><div data-component="FrameTarget"
                        id="cart-content"
                        data-option-enter-from="opacity-0"
                        data-option-enter-active="transition ease-in-out"
                        data-option-leave-active="transition ease-in-out"
                        data-option-leave-to="opacity-0">
                        <p class="opacity-50">Your cart is empty.</p>
                      </div>
                    </textarea>
                    <div data-component="FrameTriggerLoader"
                      data-option-enter-from="opacity-0 scale-0"
                      data-option-enter-active="transition duration-500 ease-out-expo"
                      data-option-leave-active="transition duration-500 ease-in-expo"
                      data-option-leave-to="opacity-0 scale-0"
                      class="flex items-center mr-auto opacity-0 scale-0">
                      {{
                        include(
                          '@ui/Icon/Icon.twig',
                          {
                            name: 'svg-spinners:ring-resize',
                            attr: {
                              class: 'block h-[0.6lh] [&>svg]:w-full [&>svg]:h-full'
                            }
                          }
                        )
                      }}
                    </div>
                    <button type="submit"
                      class="relative inline-block border-b">
                      Remove
                    </button>
                  </form>
                </article>
              </div>
            {%- endset -%}
            <input type="hidden" name="wait" value="1" />
            <textarea readonly class="hidden" name="content">
              {{ cart_content|e('html') }}
            </textarea>

            <div data-component="FrameTriggerLoader"
              data-option-enter-from="opacity-0 scale-0"
              data-option-enter-active="transition duration-500 ease-out-expo"
              data-option-leave-active="transition duration-500 ease-in-expo"
              data-option-leave-to="opacity-0 scale-0"
              class="flex items-center mr-auto opacity-0 scale-0">
              {{
                include(
                  '@ui/Icon/Icon.twig',
                  {
                    name: 'svg-spinners:ring-resize',
                    attr: {
                      class: 'block h-[0.6lh] [&>svg]:w-full [&>svg]:h-full'
                    }
                  }
                )
              }}
            </div>
            <button type="submit" class="relative inline-block border-b">
              Add to cart
            </button>
          </form>
        </div>
      </article>
    {% endfor %}
  </main>
</div>
